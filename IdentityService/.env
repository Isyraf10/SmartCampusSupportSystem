# MongoDB Configuration - Local MongoDB Compass
MONGO_URI=mongodb://localhost:27017/smart-campus-identity

# MongoDB Configuration - Tukar localhost ke host.docker.internal
# Ini supaya backend dalam Docker boleh nampak MongoDB Compass kat Windows kau
# MONGO_URI=mongodb://host.docker.internal:27017/smart-campus-identity

# Server Configuration
PORT=5000
IDENTITY_SERVICE_PORT=5000
NODE_ENV=development

# JWT Configuration 
JWT_SECRET=super_key
JWT_REFRESH_SECRET=super_key_refresh

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Service URLs (for inter-service communication)
# IT_SERVICE_URL=http://localhost:5001
# FACILITY_SERVICE_URL=http://localhost:5002
# NOTIFICATION_SERVICE_URL=http://localhost:5003

# Service URLs (TUKAR UNTUK INTER-SERVICE DOCKER COMMUNICATION)
# Dalam Docker network, kena pakai nama servis container kawan kau, bukan localhost!
IT_SERVICE_URL=http://it-service:5001
FACILITY_SERVICE_URL=http://booking-service:5002
NOTIFICATION_SERVICE_URL=http://notification-service:5003