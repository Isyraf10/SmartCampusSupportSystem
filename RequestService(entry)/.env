# MongoDB Configuration
#MONGO_ROOT_USER=admin
#MONGO_ROOT_PASSWORD=admin123

# Identity Service Configuration
#MONGODB_URI_IDENTITY=mongodb://admin:admin123@mongodb:27017/IdentityDB?authSource=admin
#JWT_SECRET=super_key
#JWT_REFRESH_SECRET=super_key_refresh
#CORS_ORIGIN=http://localhost:3000

# Frontend Configuration
#VITE_API_URL=http://localhost:5000/api/v1

# Environment
#NODE_ENV=production

# ==========================================
# DATABASE (Tembak terus ke MongoDB Compass Laptop)
# ==========================================
# Kita guna host.docker.internal sebab MongoDB ada kat luar Docker (Windows)
MONGO_URI=mongodb://host.docker.internal:27017/smart-campus-identity
MONGODB_URI_IDENTITY=mongodb://host.docker.internal:27017/smart-campus-identity

# ==========================================
# SERVER CONFIGURATION
# ==========================================
PORT=5000
IDENTITY_SERVICE_PORT=5000
NODE_ENV=development

# ==========================================
# SECURITY / AUTH (JWT)
# ==========================================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_2024
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production_2024

# ==========================================
# CORS (Benarkan Frontend Akses API)
# ==========================================
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ==========================================
# SOA SERVICE ROUTING (Inter-service Docker)
# ==========================================
# Pakai nama container kawan kau dalam Docker network, jangan pakai localhost!
IT_SERVICE_URL=http://it-service:5001
FACILITY_SERVICE_URL=http://booking-service:5002
NOTIFICATION_SERVICE_URL=http://notification-service:5003

# ==========================================
# FRONTEND CONFIGURATION
# ==========================================
VITE_API_URL=http://localhost:5000/api/v1