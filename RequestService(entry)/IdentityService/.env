# MongoDB Configuration - For Docker Compose
MONGO_URI=mongodb://mongo:27017/smart-campus-identity

# Server Configuration
PORT=5000
IDENTITY_SERVICE_PORT=5000
NODE_ENV=production

# JWT Configuration 
JWT_SECRET=super_key
JWT_REFRESH_SECRET=super_key_refresh

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:5002

# Service URLs (for inter-service Docker communication)
IT_SERVICE_URL=http://it-service:5001
FACILITY_SERVICE_URL=http://booking-service:5002
NOTIFICATION_SERVICE_URL=http://notification-service:5003
