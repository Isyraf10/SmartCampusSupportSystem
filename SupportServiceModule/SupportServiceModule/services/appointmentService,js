const AcademicModel = require('../models/academicModel');
const axios = require('axios');

exports.bookNewAppointment = (studentId, advisorName, date, callback) => {
    AcademicModel.createAppointment(studentId, advisorName, date, async (err, result) => {
        if (err) return callback(err, null);
        
        try {
            await axios.post('http://localhost:5003/api/v1/notifications', {
                recipient_id: studentId,
                title: "📅 Appointment Booked Successfully!",
                message: `Your academic advisor appointment with ${advisorName} on ${date} has been submitted.`,
                type: "academic"
            });
            console.log("✓ Notification successfully triggered to Dini's Service!");
        } catch (notificationError) {
            console.error("✗ Failed to send notification to Port 5003:", notificationError.message);
        }

        callback(null, result);
    });
};

exports.removeAppointment = (appointmentId, studentId, callback) => {
    AcademicModel.deleteAppointment(appointmentId, studentId, callback);
};